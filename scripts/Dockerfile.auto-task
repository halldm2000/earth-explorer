# Sandboxed Claude Code autonomous task runner
#
# Build:  docker build -f scripts/Dockerfile.auto-task -t worldscope-task .
# Run:    See scripts/auto-task.ps1 (handles this automatically)

FROM node:22-slim

# Install git and common tools Claude might need
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user (claude can't run --dangerously-skip-permissions as root)
RUN useradd -m -s /bin/bash claude && \
    mkdir -p /workspace && \
    chown claude:claude /workspace

# Pre-create directories that Claude Code expects to write to
# Without these, Bash tool fails with ENOENT on session-env, shell-snapshots, etc.
RUN mkdir -p /home/claude/.claude/session-env \
             /home/claude/.claude/shell-snapshots \
             /home/claude/.claude/cache \
             /home/claude/.claude/sessions \
             /home/claude/.claude/plans \
             /home/claude/.claude/projects \
             /home/claude/.claude/file-history \
             /home/claude/.claude/backups \
    && chown -R claude:claude /home/claude/.claude

# Configure git for commits inside the container
RUN su claude -c 'git config --global user.email "auto-task@worldscope.dev"' && \
    su claude -c 'git config --global user.name "Worldscope Auto-Task"'

USER claude
WORKDIR /workspace

# Default: run Claude with full autonomy inside the sandbox
ENTRYPOINT ["claude", "-p", "--dangerously-skip-permissions"]
